    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "// Track Processed — MUST be the last write per ARCHITECTURE invariant #1.\n// Replace this Code node with a Data Table 'insert row' node that stores:\n//   internetMessageId, processed_at, outcome, customer, qargo_order_id, review_reason\n// The current body just logs; swapping it out preserves connections.\nconst out=[];\nfor(const it of $input.all()){\n  const row={\n    internetMessageId: it.json.mail_id_for_dedupe || it.json.mail?.internetMessageId || null,\n    processed_at: new Date().toISOString(),\n    outcome: it.json.outcome || null,\n    customer: it.json.customer || null,\n    qargo_order_id: it.json.qargo_order_id || null,\n    review_reason: it.json.review_reason || it.json.finalize_reason || null,\n  };\n  out.push({ json: { ...it.json, tracked_row: row } });\n}\nreturn out;"
      },
