    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "// Collect attachment metadata + decoded text into item.json.attachments[].\n// For XML/JSON/text attachments we return decoded string; binary types pass through.\nconst all = $input.all();\nconst mailItem = all[0]?.json?.mail ? all[0].json : null;\nconst atts = [];\nfor (const it of all) {\n  const a = it.json;\n  if (!a || !a.name) continue;\n  const mime = (a.contentType || '').toLowerCase();\n  const filename = a.name || '';\n  let text = null;\n  if (a.contentBytes && (/xml|json|text|csv/.test(mime) || /\\.(xml|json|txt|csv)$/i.test(filename))) {\n    try { text = Buffer.from(a.contentBytes, 'base64').toString('utf8'); } catch (e) { text = null; }\n  }\n  atts.push({\n    filename,\n    mime,\n    size: a.size || 0,\n    text,\n    contentBytes: a.contentBytes || null,\n    attachmentId: a.id || null,\n    xml_json: null,\n    xlsx_rows: null,\n  });\n}\nreturn [{ json: { ...(mailItem || {}), attachments: atts } }];"
      },
